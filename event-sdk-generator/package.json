{
  "name": "event-sdk-generator-starter",
  "private": true,
  "version": "0.1.0",
  "description": "Specification-driven Event SDK Generator with TypeScript/Java targets and deployable web catalog.",
  "scripts": {
    "validate": "pnpm --filter @eventgen/cli dev validate",
    "build:catalog": "pnpm --filter @eventgen/cli dev build-catalog",
    "generate:ts": "pnpm --filter @eventgen/cli dev generate --target typescript",
    "generate:java": "pnpm --filter @eventgen/cli dev generate --target java",
    "dev:web": "pnpm --filter @eventgen/web-catalog dev",
    "build:web": "pnpm build:catalog && pnpm --filter @eventgen/web-catalog build"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@9.12.0"
}
